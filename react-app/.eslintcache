/a>\r\n        </li>\r\n      )\r\n      i++\r\n    }\r\n    return (\r\n      <nav>\r\n        <ul>{lists}</ul>\r\n      </nav>\r\n    )\r\n  }\r\n}\r\nexport default TOC\r\n","C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\components\\subject.js",["49"],"import react, { Component } from \"react\"\r\n\r\nclass subject extends Component {\r\n  render() {\r\n    return (\r\n      <header>\r\n        <h1>\r\n          <a\r\n            href=\"/\"\r\n            onClick={function (e) {\r\n              e.preventDefault()\r\n              this.props.onChangePage()\r\n            }.bind(this)}\r\n          >\r\n            {this.props.title}\r\n          </a>\r\n        </h1>\r\n        {this.props.sub}\r\n      </header>\r\n    )\r\n  }\r\n}\r\n\r\nexport default subject\r\n","C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\components\\control.js",["50"],"C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\components\\ReadContent.js",["51"],"import react, { Component } from \"react\"\r\n\r\nclass ReadContent extends Component {\r\n  render() {\r\n    return (\r\n      <article>\r\n        <h2>{this.props.title}</h2>\r\n        {this.props.desc}\r\n      </article>\r\n    )\r\n  }\r\n}\r\nexport default ReadContent\r\n","C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\components\\CreateContent.js",["52"],"import react, { Component } from \"react\"\r\n\r\nclass CreateContent extends Component {\r\n  render() {\r\n    return (\r\n      <article>\r\n        <h2>CREATE</h2>\r\n        <form\r\n          action=\"/create_process\"\r\n          method=\"post\"\r\n          onSubmit={function (e) {\r\n            e.preventDefault()\r\n            this.props.onSubmit(e.target.title.value, e.target.desc.value)\r\n          }.bind(this)}\r\n        >\r\n          <p>\r\n            <input type=\"text\" name=\"title\" placeholder=\"title\"></input>\r\n          </p>\r\n          <p>\r\n            <textarea type=\"text\" name=\"desc\" placeholder=\"desc\"></textarea>\r\n          </p>\r\n          <p>\r\n            <button type=\"submit\">submit</button>\r\n          </p>\r\n        </form>\r\n      </article>\r\n    )\r\n  }\r\n}\r\nexport default CreateContent\r\n","C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\components\\UpdateContent.js",["53"],{"ruleId":"54","replacedBy":"55"},{"ruleId":"56","replacedBy":"57"},{"ruleId":"58","severity":1,"message":"59","line":34,"column":9,"nodeType":"60","messageId":"61","endLine":34,"endColumn":14},{"ruleId":"62","severity":1,"message":"63","line":68,"column":11,"nodeType":"64","messageId":"65","endLine":68,"endColumn":19},{"ruleId":"62","severity":1,"message":"63","line":92,"column":11,"nodeType":"64","messageId":"65","endLine":92,"endColumn":19},{"ruleId":"66","severity":1,"message":"67","line":1,"column":8,"nodeType":"64","messageId":"68","endLine":1,"endColumn":13},{"ruleId":"66","severity":1,"message":"67","line":1,"column":8,"nodeType":"64","messageId":"68","endLine":1,"endColumn":13},{"ruleId":"66","severity":1,"message":"67","line":1,"column":8,"nodeType":"64","messageId":"68","endLine":1,"endColumn":13},{"ruleId":"66","severity":1,"message":"67","line":1,"column":8,"nodeType":"64","messageId":"68","endLine":1,"endColumn":13},{"ruleId":"66","severity":1,"message":"67","line":1,"column":8,"nodeType":"64","messageId":"68","endLine":1,"endColumn":13},{"ruleId":"66","severity":1,"message":"67","line":1,"column":8,"nodeType":"64","messageId":"68","endLine":1,"endColumn":13},"no-native-reassign",["69"],"no-negated-in-lhs",["70"],"no-unreachable","Unreachable code.","BreakStatement","unreachableCode","no-redeclare","'_content' is already defined.","Identifier","redeclared","no-unused-vars","'react' is defined but never used.","unusedVar","no-global-assign","no-unsafe-negation"]