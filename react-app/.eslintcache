[{"C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\index.js":"1","C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\App.js":"2","C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\reportWebVitals.js":"3","C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\components\\toc.js":"4","C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\components\\subject.js":"5","C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\components\\control.js":"6","C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\components\\ReadContent.js":"7","C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\components\\CreateContent.js":"8","C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\components\\UpdateContent.js":"9"},{"size":830,"mtime":1610699732780,"results":"10","hashOfConfig":"11"},{"size":5272,"mtime":1610598509341,"results":"12","hashOfConfig":"11"},{"size":362,"mtime":499162500000,"results":"13","hashOfConfig":"11"},{"size":973,"mtime":1610527107498,"results":"14","hashOfConfig":"11"},{"size":472,"mtime":1610518002803,"results":"15","hashOfConfig":"11"},{"size":1020,"mtime":1610597816796,"results":"16","hashOfConfig":"11"},{"size":253,"mtime":1610524732008,"results":"17","hashOfConfig":"11"},{"size":787,"mtime":1610525710783,"results":"18","hashOfConfig":"11"},{"size":1470,"mtime":1610590562897,"results":"19","hashOfConfig":"11"},{"filePath":"20","messages":"21","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"644nhk",{"filePath":"22","messages":"23","errorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"24","usedDeprecatedRules":"25"},{"filePath":"26","messages":"27","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"25"},{"filePath":"28","messages":"29","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"30","usedDeprecatedRules":"25"},{"filePath":"31","messages":"32","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"33","usedDeprecatedRules":"25"},{"filePath":"34","messages":"35","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"36","usedDeprecatedRules":"25"},{"filePath":"37","messages":"38","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"39","usedDeprecatedRules":"25"},{"filePath":"40","messages":"41","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"42","usedDeprecatedRules":"25"},{"filePath":"43","messages":"44","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"45","usedDeprecatedRules":"25"},"C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\index.js",[],"C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\App.js",["46","47","48"],"import React, { Component } from \"react\"\nimport TOC from \"./components/toc\"\nimport ReadContent from \"./components/ReadContent\"\nimport CreateContent from \"./components/CreateContent\"\nimport UpdateContent from \"./components/UpdateContent\"\nimport Subject from \"./components/subject\"\nimport Control from \"./components/control\"\nimport \"./App.css\"\n\nclass App extends Component {\n  constructor(props) {\n    super(props)\n    this.max_content_id = 3\n    this.state = {\n      mode: \"welcome\",\n      subject: { title: \"WEB\", sub: \"world wide web!\" },\n      welcome: { title: \"welcome\", desc: \"Hello, React!\" },\n      selected_id: 2,\n      contents: [\n        { id: 1, title: \"HTML\", desc: \"HTML is HiperText Markup Language\" },\n        { id: 2, title: \"CSS\", desc: \"CSS is cascading Style Sheets\" },\n        { id: 3, title: \"JS\", desc: \"Java Script\" },\n      ],\n    }\n  }\n  getReadContent() {\n    var i = 0\n    while (i < this.state.contents.length) {\n      var data = this.state.contents[i]\n      if (data.id === this.state.selected_id) {\n        return data\n        // _title = data.title\n        // _desc = data.desc\n        break\n      }\n      i++\n    }\n  }\n  getContent() {\n    var _title,\n      _desc,\n      _article = null\n    if (this.state.mode === \"welcome\") {\n      _title = this.state.welcome.title\n      _desc = this.state.welcome.desc\n      _article = <ReadContent title={_title} desc={_desc}></ReadContent>\n    } else if (this.state.mode === \"read\") {\n      var _content = this.getReadContent()\n      _article = <ReadContent title={_content.title} desc={_content.desc}></ReadContent>\n    } else if (this.state.mode === \"create\") {\n      _article = (\n        <CreateContent\n          onSubmit={function (_title, _desc) {\n            this.max_content_id = this.max_content_id + 1\n            /* this.state.contents.push({ id: this.max_content_id, title: _title, desc: _desc }) */\n            // 원본 데이터를 바꾸지 않고 복제본을 이용하기 위해 push 보단 concat을 사용. 그래야 shouldComponentUpdate 함수에서 비교를 할 수 있음\n            // var _contents = this.state.contents.concat({ id: this.max_content_id, title: _title, desc: _desc })\n            var newContents = Array.from(this.state.contents)\n            newContents.push({ id: this.max_content_id, title: _title, desc: _desc })\n            this.setState({\n              contents: newContents,\n              mode: \"read\",\n            })\n          }.bind(this)}\n        ></CreateContent>\n      )\n    } else if (this.state.mode === \"update\") {\n      var _content = this.getReadContent()\n      _article = (\n        <UpdateContent\n          id={_content.id}\n          title={_content.title}\n          desc={_content.desc}\n          onSubmit={function (_id, _title, _desc) {\n            var _contents = Array.from(this.state.contents)\n            var i = 0\n            while (i < _contents.length) {\n              if (_contents[i].id === _id) {\n                _contents[i] = { id: _id, title: _title, desc: _desc }\n                break\n              }\n              i++\n            }\n            this.setState({\n              contents: _contents,\n              mode: \"read\",\n            })\n          }.bind(this)}\n        ></UpdateContent>\n      )\n    } else if (this.state.mode === \"delete\") {\n      var _content = this.getReadContent()\n    }\n    return _article\n  }\n  // react 에서는 props나 state 가 바뀌면 render() 함수를 다시 실행하여 html을 그린다.\n  render() {\n    return (\n      <div className=\"App\">\n        <Subject\n          title={this.state.subject.title}\n          sub={this.state.subject.sub}\n          onChangePage={function () {\n            this.setState({ mode: \"welcome\" })\n          }.bind(this)}\n        ></Subject>\n        <Control\n          onChangeMode={function (action) {\n            if (action === \"delete\") {\n              if (window.confirm(\"really?\")) {\n                var _contents = Array.from(this.state.contents)\n                var i = 0\n                while (i < _contents.length) {\n                  if (_contents[i].id === this.state.selected_id) {\n                    _contents.splice(i, 1)\n                    break\n                  }\n                  i++\n                }\n                alert(\"deleted!\")\n                this.setState({ mode: \"welcome\", contents: _contents })\n              }\n            } else {\n              this.setState({ mode: action })\n            }\n          }.bind(this)}\n        ></Control>\n        <TOC\n          onChangePage={function (id) {\n            this.setState({ mode: \"read\", selected_id: Number(id) })\n          }.bind(this)}\n          data={this.state.contents}\n        ></TOC>\n        {this.getContent()}\n      </div>\n    )\n  }\n}\n\nexport default App\n\n// function App() {\n//   return (\n//     <div className=\"App\">\n//       <header className=\"App-header\">\n//         <img src={logo} className=\"App-logo\" alt=\"logo\" />\n//         <p>\n//           Edit <code>src/App.js</code> and save to reload.\n//         </p>\n//         <a\n//           className=\"App-link\"\n//           href=\"https://reactjs.org\"\n//           target=\"_blank\"\n//           rel=\"noopener noreferrer\"\n//         >\n//           Learn React\n//         </a>\n//       </header>\n//     </div>\n//   );\n// }\n",["49","50"],"C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\reportWebVitals.js",[],"C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\components\\toc.js",["51"],"import react, { Component } from \"react\"\r\n\r\nclass TOC extends Component {\r\n  shouldComponentUpdate(newProps, newState) {\r\n    if (newProps.data === this.props.data) {\r\n      return false\r\n    }\r\n    return true\r\n  }\r\n  render() {\r\n    console.log(\"toc============\")\r\n    var lists = []\r\n    var data = this.props.data\r\n    var i = 0\r\n    while (i < data.length) {\r\n      lists.push(\r\n        // 반복적으로 생성되는 태그에는 구분할 수 있는 key 값을 넣어줘야 함\r\n        <li key={data[i].id}>\r\n          <a\r\n            href={\"/content/\" + data[i].id}\r\n            data-id={data[i].id}\r\n            onClick={function (e) {\r\n              e.preventDefault()\r\n\r\n              this.props.onChangePage(e.target.dataset.id)\r\n            }.bind(this)}\r\n          >\r\n            {data[i].title}\r\n          </a>\r\n        </li>\r\n      )\r\n      i++\r\n    }\r\n    return (\r\n      <nav>\r\n        <ul>{lists}</ul>\r\n      </nav>\r\n    )\r\n  }\r\n}\r\nexport default TOC\r\n","C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\components\\subject.js",["52"],"import react, { Component } from \"react\"\r\n\r\nclass subject extends Component {\r\n  render() {\r\n    return (\r\n      <header>\r\n        <h1>\r\n          <a\r\n            href=\"/\"\r\n            onClick={function (e) {\r\n              e.preventDefault()\r\n              this.props.onChangePage()\r\n            }.bind(this)}\r\n          >\r\n            {this.props.title}\r\n          </a>\r\n        </h1>\r\n        {this.props.sub}\r\n      </header>\r\n    )\r\n  }\r\n}\r\n\r\nexport default subject\r\n","C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\components\\control.js",["53"],"import react, { Component } from \"react\"\r\n\r\nclass Control extends Component {\r\n  render() {\r\n    return (\r\n      <ul>\r\n        <li>\r\n          <button\r\n            value=\"create\"\r\n            onClick={function (e) {\r\n              e.preventDefault()\r\n              this.props.onChangeMode(e.target.value)\r\n            }.bind(this)}\r\n          >\r\n            create\r\n          </button>\r\n        </li>\r\n        <li>\r\n          <button\r\n            value=\"update\"\r\n            onClick={function (e) {\r\n              e.preventDefault()\r\n              this.props.onChangeMode(e.target.value)\r\n            }.bind(this)}\r\n          >\r\n            update\r\n          </button>\r\n        </li>\r\n        <li>\r\n          <button\r\n            value=\"delete\"\r\n            onClick={function (e) {\r\n              e.preventDefault()\r\n              this.props.onChangeMode(e.target.value)\r\n            }.bind(this)}\r\n          >\r\n            delete\r\n          </button>\r\n        </li>\r\n      </ul>\r\n    )\r\n  }\r\n}\r\nexport default Control\r\n","C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\components\\ReadContent.js",["54"],"import react, { Component } from \"react\"\r\n\r\nclass ReadContent extends Component {\r\n  render() {\r\n    return (\r\n      <article>\r\n        <h2>{this.props.title}</h2>\r\n        {this.props.desc}\r\n      </article>\r\n    )\r\n  }\r\n}\r\nexport default ReadContent\r\n","C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\components\\CreateContent.js",["55"],"import react, { Component } from \"react\"\r\n\r\nclass CreateContent extends Component {\r\n  render() {\r\n    return (\r\n      <article>\r\n        <h2>CREATE</h2>\r\n        <form\r\n          action=\"/create_process\"\r\n          method=\"post\"\r\n          onSubmit={function (e) {\r\n            e.preventDefault()\r\n            this.props.onSubmit(e.target.title.value, e.target.desc.value)\r\n          }.bind(this)}\r\n        >\r\n          <p>\r\n            <input type=\"text\" name=\"title\" placeholder=\"title\"></input>\r\n          </p>\r\n          <p>\r\n            <textarea type=\"text\" name=\"desc\" placeholder=\"desc\"></textarea>\r\n          </p>\r\n          <p>\r\n            <button type=\"submit\">submit</button>\r\n          </p>\r\n        </form>\r\n      </article>\r\n    )\r\n  }\r\n}\r\nexport default CreateContent\r\n","C:\\Users\\PI190037\\Desktop\\hyuzni\\project\\study\\react-app\\src\\components\\UpdateContent.js",["56"],"import react, { Component } from \"react\"\r\n\r\nclass UpdateContent extends Component {\r\n  constructor(props) {\r\n    super(props)\r\n    this.state = {\r\n      id: this.props.id,\r\n      title: this.props.title,\r\n      desc: this.props.desc,\r\n    }\r\n    this.inputFormHandler = this.inputFormHandler.bind(this)\r\n  }\r\n  inputFormHandler(e) {\r\n    this.setState({ [e.target.name]: e.target.value })\r\n  }\r\n  render() {\r\n    return (\r\n      <article>\r\n        <h2>Update</h2>\r\n        <form\r\n          action=\"/update_process\"\r\n          method=\"post\"\r\n          onSubmit={function (e) {\r\n            e.preventDefault()\r\n            this.props.onSubmit(this.state.id, this.state.title, this.state.desc)\r\n          }.bind(this)}\r\n        >\r\n          <input type=\"hidden\" name=\"id\" value={this.state.id}></input>\r\n          <p>\r\n            <input\r\n              type=\"text\"\r\n              name=\"title\"\r\n              placeholder=\"title\"\r\n              value={this.state.title}\r\n              onChange={this.inputFormHandler}\r\n            ></input>\r\n          </p>\r\n          <p>\r\n            <textarea\r\n              type=\"text\"\r\n              name=\"desc\"\r\n              placeholder=\"desc\"\r\n              value={this.state.desc}\r\n              onChange={this.inputFormHandler}\r\n            ></textarea>\r\n          </p>\r\n          <p>\r\n            <button type=\"submit\">submit</button>\r\n          </p>\r\n        </form>\r\n      </article>\r\n    )\r\n  }\r\n}\r\nexport default UpdateContent\r\n",{"ruleId":"57","severity":1,"message":"58","line":34,"column":9,"nodeType":"59","messageId":"60","endLine":34,"endColumn":14},{"ruleId":"61","severity":1,"message":"62","line":68,"column":11,"nodeType":"63","messageId":"64","endLine":68,"endColumn":19},{"ruleId":"61","severity":1,"message":"62","line":92,"column":11,"nodeType":"63","messageId":"64","endLine":92,"endColumn":19},{"ruleId":"65","replacedBy":"66"},{"ruleId":"67","replacedBy":"68"},{"ruleId":"69","severity":1,"message":"70","line":1,"column":8,"nodeType":"63","messageId":"71","endLine":1,"endColumn":13},{"ruleId":"69","severity":1,"message":"70","line":1,"column":8,"nodeType":"63","messageId":"71","endLine":1,"endColumn":13},{"ruleId":"69","severity":1,"message":"70","line":1,"column":8,"nodeType":"63","messageId":"71","endLine":1,"endColumn":13},{"ruleId":"69","severity":1,"message":"70","line":1,"column":8,"nodeType":"63","messageId":"71","endLine":1,"endColumn":13},{"ruleId":"69","severity":1,"message":"70","line":1,"column":8,"nodeType":"63","messageId":"71","endLine":1,"endColumn":13},{"ruleId":"69","severity":1,"message":"70","line":1,"column":8,"nodeType":"63","messageId":"71","endLine":1,"endColumn":13},"no-unreachable","Unreachable code.","BreakStatement","unreachableCode","no-redeclare","'_content' is already defined.","Identifier","redeclared","no-native-reassign",["72"],"no-negated-in-lhs",["73"],"no-unused-vars","'react' is defined but never used.","unusedVar","no-global-assign","no-unsafe-negation"]